NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
RESEND_API_KEY=re_your_resend_api_key_here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# R.7: activa el envío real de emails (notificación a Matías al crear/modificar
# pedidos, etc.). Si no es "true" se loguea el intento pero no se envía.
EMAIL_ENABLED=false

# TusFacturas - Facturación electrónica
TUSFACTURAS_API_KEY=71305
TUSFACTURAS_API_TOKEN=your-api-token-here
TUSFACTURAS_USER_TOKEN=your-user-token-here
TUSFACTURAS_PUNTO_VENTA=5
TUSFACTURAS_MODO=testing
